# Copy to .env and adjust as needed. These values configure the app
# at runtime and are good candidates to externalise into ConfigMaps /
# Secrets when this repo is converted to Kubernetes during training.

# Friendly application name shown on the / and /version routes.
APP_NAME=starter-app

# Application version string shown on the / and /version routes.
APP_VERSION=1.0.0

# Greeting returned by the / route.
GREETING=Hello, world!

# Port the app listens on inside the container.
PORT=8080
